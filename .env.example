# CourtListener API Configuration
COURTLISTENER_API_TOKEN=your_api_token_here
COURTLISTENER_BASE_URL=https://www.courtlistener.com/api/rest/v4
COURTLISTENER_TIMEOUT=30

# Optional: browser session ID for web-only endpoints (e.g. docket CSV export).
# Find it in DevTools → Application → Cookies → sessionid
COURTLISTENER_SESSION_ID=

# Logging
LOG_LEVEL=DEBUG
LOG_TO_FILE=false

# Output Configuration
OUTPUT_FORMAT=xlsx
INCLUDE_TIMESTAMP=true
